    {
      "name": "Reconciliation — discrepancies",
      "description": "GET /reconciliation/discrepancies — surfaces transactions in nonsensical or stuck states.\n\nDetectors:\n- conflicting_events — same txn has both payment_failed and settled events (the seeded pair above lands here)\n- stuck_in_processed — current_status='processed', processed_at older than threshold\n- stuck_in_initiated — current_status='initiated', initiated_at older than threshold",
      "item": [
        {
          "name": "All — every detector runs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reconciliation/discrepancies",
              "host": ["{{baseUrl}}"],
              "path": ["reconciliation", "discrepancies"]
            }
          }
        },
        {
          "name": "Only conflicting_events (money shot)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reconciliation/discrepancies?type=conflicting_events",
              "host": ["{{baseUrl}}"],
              "path": ["reconciliation", "discrepancies"],
              "query": [{ "key": "type", "value": "conflicting_events" }]
            },
            "description": "Returns the 2ea525e0-... transaction seeded earlier — the one with both a failed and a settled event."
          }
        },
        {
          "name": "Only stuck_in_processed",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reconciliation/discrepancies?type=stuck_in_processed",
              "host": ["{{baseUrl}}"],
              "path": ["reconciliation", "discrepancies"],
              "query": [{ "key": "type", "value": "stuck_in_processed" }]
            }
          }
        },
        {
          "name": "Per merchant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reconciliation/discrepancies?merchant_id=merchant_1",
              "host": ["{{baseUrl}}"],
              "path": ["reconciliation", "discrepancies"],
              "query": [{ "key": "merchant_id", "value": "merchant_1" }]
            }
          }
        },
        {
          "name": "Custom thresholds — 1 week stale window",
          "request": {
            "method": "GET",
